{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@mahjong/shared$": "<rootDir>/../../packages/shared/src",
    "^@mahjong/engine$": "<rootDir>/../../packages/mahjong-engine/src"
  }
}
